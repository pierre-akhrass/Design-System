{
  "name": "ogilvy-design-system",
  "private": false,
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/ogilvy-design-system.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/ogilvy-design-system.css": "./dist/ogilvy-design-system.css",
    "./styles.css": "./dist/ogilvy-design-system.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:tokens && vite build",
    "build:tokens": "style-dictionary build --config style-dictionary.config.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest --project storybook run",
    "test-storybook:coverage": "vitest --project storybook run --coverage",
    "test-a11y": "vitest --project storybook run",
    "visual-test": "chromatic --exit-once-uploaded",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-vitest": "^10.4.4",
    "@storybook/react-vite": "^10.4.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "mockdate": "^3.0.5",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "playwright": "^1.60.0",
    "sass": "^1.100.0",
    "storybook": "^10.4.2",
    "style-dictionary": "^5.4.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.2",
    "vite-plugin-svgr": "^5.2.0"
  },
  "dependencies": {
    "@fontsource/noto-sans": "^5.2.10",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
